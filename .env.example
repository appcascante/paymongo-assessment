# Test Environment Variables

# LLM Test Generation
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Default test target (staging | uat | production)
TEST_ENV=staging

# Staging URLs (defaults to localhost so tests run against `npm run app:start` out of the box)
STAGING_BASE_URL=http://localhost:3000
STAGING_API_URL=http://localhost:8080

# Path to the app-under-test checkout (Go API + Next.js frontend).
# Leave unset to use the default sibling directory `../paymongo-assessment-app-code`.
# APP_CODE_DIR=C:\path\to\app-under-test

# Environment Selection (staging, uat, production)
TEST_ENV=staging

# API Configuration
API_SECRET_KEY=your-api-key-here
STAGING_API_URL=https://api-staging.example.com
UAT_API_URL=https://api-uat.example.com
PROD_API_URL=https://api.example.com

# Web Application URLs
STAGING_BASE_URL=https://staging.example.com
UAT_BASE_URL=https://uat.example.com
PROD_BASE_URL=https://example.com

# Test User Credentials
TEST_USERNAME=test@example.com
TEST_PASSWORD=

# Browser Configuration
HEADLESS=true
SLOW_MO=0
TIMEOUT=30000

# Reporting and Debugging
GENERATE_REPORT=true
TAKE_SCREENSHOTS=true
RECORD_VIDEOS=false
ENABLE_TRACING=false
